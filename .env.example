# Asmakta — environment configuration. Copy to `.env` and fill in.
# See docs/plan.md §9 for where each value comes from and expected costs.

# --- Postgres (Neon in prod; a local cluster in dev) ---
# Neon: neon.tech -> new project -> pooled connection string. pgvector is on every plan.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Anthropic (answering + eval judge) ---
# console.anthropic.com -> create key. Pay-as-you-go, ~$2-5/mo at the default config.
ANTHROPIC_API_KEY=

# --- Voyage AI (embeddings + optional rerank) ---
# voyageai.com (MongoDB). 200M free tokens one-time; ~$0 at demo scale.
VOYAGE_API_KEY=

# --- Admin auth (guards upload/reingest/fixture routes) ---
# Any random string.
ADMIN_TOKEN=

# --- Optional overrides (defaults live in src/config/models.ts) ---
# ANSWERING_MODEL=claude-sonnet-5
# JUDGE_MODEL=claude-opus-4-8
# EMBEDDING_MODEL=voyage-4-lite

# --- Server ---
PORT=3000
# Comma-separated allowed origins for CORS (the web app URL). Empty = allow all in dev.
CORS_ORIGINS=

# --- Eval ---
# The "green" bar. `npm run eval` exits non-zero below this.
EVAL_TARGET_PASS_RATE=0.90
# Hard per-run cost cap (USD). The harness aborts if projected/actual spend exceeds this.
EVAL_MAX_COST_USD=2.00
