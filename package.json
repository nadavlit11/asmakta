{
  "name": "asmakta",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Asmakta — bilingual (Hebrew/English) document-Q&A assistant with a published eval report. Every answer is backed by a cited source, or there is no answer.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "start": "tsx src/api/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts up",
    "ingest": "tsx scripts/ingest-file.ts",
    "seed:corpus": "tsx scripts/seed-corpus.ts",
    "seed:fixtures": "tsx scripts/seed-fixtures.ts",
    "eval": "tsx src/eval/cli.ts",
    "scratch:embed": "tsx scripts/scratch-embed.ts",
    "scratch:retrieve": "tsx scripts/scratch-retrieve.ts",
    "scratch:ask": "tsx scripts/scratch-ask.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "cheerio": "^1.0.0",
    "fastify": "^5.2.0",
    "mammoth": "^1.8.0",
    "pg": "^8.13.1",
    "unpdf": "^0.12.1",
    "voyageai": "^0.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
